{
  "name": "@eth-optimism/actions-sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/ethereum-optimism/actions.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/ethereum-optimism/actions/tree/main/packages/sdk#readme",
  "bugs": {
    "url": "https://github.com/ethereum-optimism/actions/issues"
  },
  "type": "module",
  "sideEffects": false,
  "version": "0.8.1",
  "description": "TypeScript SDK for Actions",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/*",
    "src/*"
  ],
  "exports": {
    ".": {
      "react": "./dist/index.react.js",
      "import": "./dist/index.node.js",
      "default": "./dist/index.node.js"
    },
    "./react": "./dist/index.react.js",
    "./node": "./dist/index.node.js"
  },
  "typesVersions": {
    "*": {
      "react": [
        "dist/index.react.d.ts"
      ],
      "node": [
        "dist/index.node.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsc && node ../../node_modules/resolve-tspaths/dist/main.js",
    "clean": "rm -rf dist types tsconfig.tsbuildinfo",
    "docs": "typedoc",
    "lint": "eslint \"**/*.{ts,tsx}\" && prettier --check \"**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"**/*.{ts,tsx}\" --fix && prettier \"**/*.{ts,tsx}\" --write --log-level=warn",
    "test": "vitest --run --project unit",
    "test:network": "vitest --run --project network",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "keywords": [
    "actions",
    "typescript",
    "sdk"
  ],
  "author": "Optimism PBC",
  "license": "MIT",
  "dependencies": {
    "@eth-optimism/viem": "^0.4.13",
    "@morpho-org/blue-sdk": ">=4.13.1 <4.14.0",
    "@morpho-org/blue-sdk-viem": ">=3.2.0 <3.3.0",
    "@morpho-org/morpho-ts": ">=2.4.6 <2.9.0",
    "permissionless": ">=0.2.57 <0.4.0"
  },
  "peerDependencies": {
    "@dynamic-labs/ethereum": ">=4.31.4 <5.0.0",
    "@dynamic-labs/waas-evm": ">=4.31.4 <5.0.0",
    "@dynamic-labs/wallet-connector-core": ">=4.31.4 <5.0.0",
    "@privy-io/react-auth": ">=2.24.0 <3.0.0",
    "@privy-io/node": ">=0.3.0 <0.4.0",
    "@turnkey/core": ">=1.1.1 <2.0.0",
    "@turnkey/http": ">=3.12.1 <4.0.0",
    "@turnkey/sdk-server": ">=4.9.1 <5.0.0",
    "@turnkey/react-wallet-kit": ">=1.1.1 <2.0.0",
    "@turnkey/viem": ">=0.14.1 <0.15.0",
    "viem": ">=2.33.0 <2.34.0"
  },
  "peerDependenciesMeta": {
    "@dynamic-labs/ethereum": {
      "optional": true
    },
    "@dynamic-labs/waas-evm": {
      "optional": true
    },
    "@dynamic-labs/wallet-connector-core": {
      "optional": true
    },
    "@privy-io/react-auth": {
      "optional": true
    },
    "@privy-io/node": {
      "optional": true
    },
    "@turnkey/core": {
      "optional": true
    },
    "@turnkey/http": {
      "optional": true
    },
    "@turnkey/sdk-server": {
      "optional": true
    },
    "@turnkey/react-wallet-kit": {
      "optional": true
    },
    "@turnkey/viem": {
      "optional": true
    }
  },
  "devDependencies": {
    "@turnkey/core": "1.8.3",
    "@turnkey/http": "3.15.0",
    "@turnkey/react-wallet-kit": "1.6.3",
    "@turnkey/sdk-server": "4.12.1",
    "@turnkey/viem": "0.14.32",
    "@types/node": "22.14.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.31.0",
    "prettier": "~3.9.6",
    "tsx": "^4.7.1",
    "typescript": "^5.2.2",
    "viem": "2.55.8",
    "vitest": "^3.2.7"
  }
}
